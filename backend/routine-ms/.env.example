# ─────────────────────────────────────────────────────────
# routine-ms — variables d'environnement
# Copier ce fichier en .env et adapter les valeurs si besoin
# ─────────────────────────────────────────────────────────

# Port d'écoute du microservice
PORT=3001

# URI de connexion MongoDB
# En local  : mongodb://localhost:27017/routine-db
# En Docker : mongodb://mongo:27017/routine-db
MONGO_URI=mongodb://localhost:27017/routine-db

# Serveur Eureka
# En local  : localhost
# En Docker : eureka-server
EUREKA_HOST=localhost
EUREKA_PORT=8761

# URI RabbitMQ
# En local  : amqp://guest:guest@localhost:5672
# En Docker : amqp://guest:guest@rabbitmq:5672
RABBITMQ_URI=amqp://guest:guest@localhost:5672

# Nom enregistré dans Eureka (doit être en MAJUSCULES)
SERVICE_NAME=ROUTINE-MS
