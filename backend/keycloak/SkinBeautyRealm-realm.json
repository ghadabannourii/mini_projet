{
  "realm": "SkinBeautyRealm",
  "displayName": "SkinBeauty — Companion Dermatologique",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 3600,

  "roles": {
    "realm": [
      { "name": "user",  "description": "Accès en lecture aux ressources SkinBeauty" },
      { "name": "admin", "description": "Accès complet CRUD sur tous les microservices" }
    ]
  },

  "clients": [
    {
      "clientId": "skinbeauty-frontend",
      "name": "SkinBeauty Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:5173/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:5173"],
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    }
  ],

  "users": [
